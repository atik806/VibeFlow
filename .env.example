# ──────────────────────────────────────────────────────────────
# Server-only secrets (no VITE_ prefix — NEVER ship to browser).
# These are read by api/generate-image.js and the Vite dev
# middleware. Without them, /api/generate-image returns 503.
# ──────────────────────────────────────────────────────────────
HF_TOKEN=your_huggingface_token_here
HF_MODEL=stabilityai/stable-diffusion-xl-base-1.0
HF_PROVIDER=fal-ai

# ──────────────────────────────────────────────────────────────
# Optional: Supabase (server / scripts / future API routes).
# Not injected into the Vite client unless you add VITE_ copies below.
# ──────────────────────────────────────────────────────────────
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_ANON_KEY=your_anon_or_publishable_key_here

# ──────────────────────────────────────────────────────────────
# Public (VITE_-prefixed) config — embedded in the browser bundle.
# Use for Supabase from React: createClient(url, anonKey)
# Never put service_role keys here.
# ──────────────────────────────────────────────────────────────
VITE_APP_URL=http://localhost:5173
VITE_CONTACT_EMAIL=hello@vibeflow.app
VITE_BRAND=Vibe Flow

# VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Use ONE of the key variable names (same dashboard value):
# VITE_SUPABASE_ANON_KEY=your_anon_or_publishable_key_here
# VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_or_publishable_key_here
