# ──────────────────────────────────────────────────────────────
# Server-only secrets (no VITE_ prefix — NEVER ship to browser).
# These are read by api/generate-image.js and the Vite dev
# middleware. Without them, /api/generate-image returns 503.
# ──────────────────────────────────────────────────────────────
HF_TOKEN=your_huggingface_token_here
HF_MODEL=stabilityai/stable-diffusion-xl-base-1.0
HF_PROVIDER=fal-ai

# ──────────────────────────────────────────────────────────────
# Public (VITE_-prefixed) config — safe to ship to the browser.
# ──────────────────────────────────────────────────────────────
VITE_APP_URL=http://localhost:5173
VITE_CONTACT_EMAIL=hello@vibeflow.app
VITE_BRAND=Vibe Flow
